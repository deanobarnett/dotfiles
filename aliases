# Unix
alias ls="exa"
alias l="ls -al"
alias ln="ln -v"
alias mkdir="mkdir -p"
alias v="nvim"
alias c="cd"
alias rweb="cd ~/Developer/src/github.com/KanisiTech/rotor-web"
alias mkit="cd ~/Developer/src/github.com/moneykit/moneykit-api"

# Docker
alias dc="docker-compose"
alias dstats='docker stats --format "table {{.Name}}:\t{{.MemUsage}}\t{{.CPUPerc}}"'

# Git
alias gl="git log --decorate --oneline --graph -10"
alias gaa="git add --all"
alias gco="git checkout"
alias gd="git diff"
alias gdc="git diff --cached"
alias gcm="git commit -vS"
alias gp="git push"
alias gpf="git push -f"
alias pull-master="git pull --rebase origin master"
alias gplm="git pull --rebase origin master"
alias grb='git branch --sort=-committerdate | head -n 20'

# K8s
alias k=kubectl

# Ruby / Rails
alias b="bundle"
alias spec="rspec"
alias lint-staged="git diff --cached --stat --name-only | xargs rubocop -A"
alias migrate="rake db:migrate db:rollback && rake db:migrate"
alias open-migration="v `g status | ag migrate | xargs`"

# Python
alias pip="pip3"
alias lint-py="dc run --rm api black app && mypy -m app.main && isort app && flake8"

# Pretty print the path
alias path='echo $PATH | tr -s ":" "\n"'

# Common files
alias todo="nvim ~/TODO.md"
alias notes="nvim ~/notes.md"

# Misc
alias wthr="curl wttr.in/Belfast"
alias weather="curl v2.wttr.in/Belfast"

# Include custom aliases
[[ -f ~/.aliases.local ]] && source ~/.aliases.local
