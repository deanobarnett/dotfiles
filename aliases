# Unix
alias ls="exa"
alias l="ls -al"
alias ln="ln -v"
alias mkdir="mkdir -p"
alias v="nvim"
alias c="cd"
alias dev="cd ~/Developer/src"

# Git
alias gl="git log --all --decorate --oneline --graph -10"
alias gaa="git add --all"
alias gco="git checkout"
alias gd="git diff"
alias gdc="git diff --cached"
alias gcm="git commit -vS"
alias gp="git push"
alias gpf="git push -f"

# Ruby
alias b="bundle"
alias spec="rspec"
alias rubocop-diff="git ls-files -m | xargs ls -1 2>/dev/null | grep '\.rb$' | xargs rubocop"

# Pretty print the path
alias path='echo $PATH | tr -s ":" "\n"'

# Common files
alias todo="nvim ~/TODO.md"

# Include custom aliases
[[ -f ~/.aliases.local ]] && source ~/.aliases.local
